{#
/**
 * @file
 * Template for a single appointment card.
 *
 * Available variables:
 * - role:         'hosting' | 'attended' | 'attending' | 'hosted' | 'all'
 * - role_label:   Human-readable role string.
 * - date:         Formatted date string, e.g. "Wed, Mar 11".
 * - time:         Formatted time range, e.g. "4:00–5:00 pm".
 * - url:          Path to the appointment node.
 * - host:         Facilitator display name.
 * - member:       Member (node owner) display name.
 * - member_uid:   Member user ID (for pending badges link).
 * - pending_url:  URL to member's pending badges (hosting/all only).
 * - purpose:      Appointment purpose label.
 * - badges:       Array of badge term names.
 * - note:         Optional note text.
 * - is_past:      Boolean, TRUE for past appointments.
 * - feedback_url: URL for the feedback form (past only).
 */
#}
<div class="appt-card appt-card--{{ role }}" data-href="{{ url }}">

  <div class="appt-card__header">
    <div class="appt-card__header-top">
      <span class="appt-card__role-badge appt-card__role-badge--{{ role }}">{{ role_label }}</span>
      <div class="appt-card__when">
        <span class="appt-card__date">{{ date }}</span>
        {% if time %}
          <span class="appt-card__time">{{ time }}</span>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="appt-card__body">
    {% if role == 'all' %}
      <div class="appt-card__person">
        <span class="appt-card__person-label">Volunteer</span>
        <span class="appt-card__person-name">{{ host }}</span>
        {% if host_area %}
          <span class="appt-card__host-area">{{ host_area }}</span>
        {% endif %}
      </div>
      <div class="appt-card__person">
        <span class="appt-card__person-label">Member{% if members|length > 1 %}s{% endif %}</span>
        <span class="appt-card__person-name">{{ members|join(', ') ?: member }}</span>
      </div>
    {% elseif role == 'hosting' or role == 'hosted' %}
      <div class="appt-card__person">
        <span class="appt-card__person-label">Member{% if members|length > 1 %}s{% endif %}</span>
        <span class="appt-card__person-name">{{ members|join(', ') ?: member }}</span>
      </div>
    {% else %}
      <div class="appt-card__person">
        <span class="appt-card__person-label">Volunteer</span>
        <span class="appt-card__person-name">{{ host }}</span>
        {% if host_area %}
          <span class="appt-card__host-area">{{ host_area }}</span>
        {% endif %}
      </div>
    {% endif %}

    {% if purpose %}
      <div class="appt-card__purpose">{{ purpose }}</div>
    {% endif %}

    {% if badges %}
      <div class="appt-card__badges">
        {% for badge in badges %}
          <span class="appt-card__badge-pill">{{ badge }}</span>
        {% endfor %}
      </div>
    {% endif %}

    {% if note %}
      <div class="appt-card__note">{{ note }}</div>
    {% endif %}

    {% if faces %}
      <div class="appt-card__faces">
        {% for face in faces %}
          <a
            href="{{ face.profile_url }}"
            class="appt-card__face"
            title="{{ face.name }} ({{ face.label }})"
            onclick="event.stopPropagation()"
          >
            {% if face.img_html %}
              {{ face.img_html|raw }}
            {% else %}
              <div class="appt-face__initials">{{ face.initials }}</div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% if pending_url or join_url or (is_past and feedback_url) %}
    <div class="appt-card__footer">
      {% if pending_url %}
        <a href="{{ pending_url }}" class="appt-card__pending-link" onclick="event.stopPropagation()">
          Pending Badges →
        </a>
      {% endif %}
      {% if join_url %}
        <a href="{{ join_url }}" class="appt-card__join-link" onclick="event.stopPropagation()">
          Join Session →
        </a>
      {% endif %}
      {% if is_past and feedback_url %}
        <a href="{{ feedback_url }}" class="appt-card__feedback-link" onclick="event.stopPropagation()">
          Leave Feedback →
        </a>
      {% endif %}
    </div>
  {% endif %}

</div>
