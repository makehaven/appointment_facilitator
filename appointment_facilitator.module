/**
 * Compute effective capacity for an appointment node.
 *
 * Capacity is the minimum of the capacities defined on the appointment's
 * "badges" (taxonomy terms) and the facilitator's own capacity limit from
 * their profile.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The appointment node.
 *
 * @return int
 *   The effective capacity, defaulting to 1.
 */
function appointment_facilitator_effective_capacity(NodeInterface $node): int {
  $caps = [];

  // Badge capacities.
  if ($node->hasField('field_appointment_badges') && !$node->get('field_appointment_badges')->isEmpty()) {
    foreach ($node->get('field_appointment_badges')->referencedEntities() as $term) {
      if (is_object($term) && $term->hasField('field_badge_capacity') && !$term->get('field_badge_capacity')->isEmpty()) {
        $caps[] = (int) $term->get('field_badge_capacity')->value;
      }
    }
  }

  // Facilitator capacity from Profile (configurable bundle).
  if ($node->hasField('field_appointment_host') && !$node->get('field_appointment_host')->isEmpty()) {
    $user = $node->get('field_appointment_host')->entity;
    $bundle = \Drupal::config('appointment_facilitator.settings')->get('facilitator_profile_bundle') ?: 'coordinator';
    if ($user && \Drupal::moduleHandler()->moduleExists('profile') && $bundle) {
      $profiles = \Drupal::entityTypeManager()->getStorage('profile')->loadByUser($user, $bundle);
      if ($profiles) {
        // loadByUser() may return a single entity or a keyed array depending on
        // the Profile module version; handle both without iterating over the
        // entity itself (which would yield FieldItemList objects, not the profile).
        $profile = is_array($profiles) ? reset($profiles) : $profiles;
        if (is_object($profile) && $profile->hasField('field_coordinator_capacity') && !$profile->get('field_coordinator_capacity')->isEmpty()) {
          $caps[] = (int) $profile->get('field_coordinator_capacity')->value;
        }
      }
    }
  }

  // System-wide cap contributes 1 primary + N joiners as a total ceiling.
  $system_cap = (int) (\Drupal::config('appointment_facilitator.settings')->get('system_wide_joiner_cap') ?? 0);
  $caps[] = 1 + $system_cap;

  $caps = array_filter(array_map('intval', $caps), fn($v) => $v > 0);
  return $caps ? min($caps) : 1;
}

/**
 * Implements hook_entity_view().
 *
 * Adds appointment join controls and badge-request quick approval actions.
 */
function appointment_facilitator_entity_view(array &$build, EntityInterface $entity, $display = NULL, $view_mode = NULL): void {
  // Support Drupal's current hook signature and older direct test calls that
  // passed ($build, $entity, $view_mode, $langcode).
  if (is_string($display) && is_string($view_mode)) {
    $view_mode = $display;
    $display = NULL;
  }
  elseif ($view_mode === NULL && is_string($display)) {
    $view_mode = $display;
    $display = NULL;
  }

  if ($display !== NULL && !$display instanceof EntityViewDisplayInterface) {
    return;
  }

  if ($entity->getEntityTypeId() === 'taxonomy_term' && $entity instanceof TermInterface && $entity->bundle() === 'badges') {
    if ($display) {
      _appointment_facilitator_attach_badge_status_pseudo_fields($build, $entity, $display);
    }

    if ($view_mode === 'full') {
      // The badge image renders as a centered hero above the H1 via
      // preprocess_page_title; suppress the in-body field render so the
      // image doesn't appear twice on the page.
      if (isset($build['field_member_badge_image'])) {
        $build['field_member_badge_image']['#access'] = FALSE;
      }
      _appointment_facilitator_enforce_badge_page_flow($build, $entity);
      _appointment_facilitator_format_badge_checklist($build, $entity);
      _appointment_facilitator_attach_video_watched_form($build, $entity);
      // Popularity stats now live in the pre_content region via
      // BadgePopularityStatsBlock — the inline render below is suppressed
      // to avoid duplicating them on the page.
      _appointment_facilitator_attach_badge_next_step_banner($build, $entity);
      _appointment_facilitator_decorate_prerequisite_field($build, $entity);
      $build['#attached']['library'][] = 'appointment_facilitator/badge_video_timestamps';
      $build['#attached']['library'][] = 'appointment_facilitator/badge_schedule_grid';

      // Paid private session sits at the bottom of the page as a true
      // last-resort fallback. Only render it when the upcoming-options it
      // claims to fall back from are actually visible to this viewer —
      // otherwise it becomes the ONLY visible CTA (anonymous users and
      // logged-in members without a pending instance have the schedule
      // hidden by enforce_badge_page_flow), making "paid" appear to be
      // the only path to the badge.
      if (_appointment_facilitator_paid_private_fallback_visible($entity)) {
        try {
          /** @var \Drupal\appointment_facilitator\Controller\BadgeNextStepsController $next_steps */
          $next_steps = \Drupal::classResolver()->getInstanceFromDefinition(BadgeNextStepsController::class);
          $build['appointment_facilitator_paid_private_fallback'] = $next_steps->buildPaidPrivateSessionFallback($entity);
          $build['appointment_facilitator_paid_private_fallback']['#weight'] = 200;
          $build['#cache']['contexts'][] = 'user';
          $build['#cache']['max-age'] = 0;
        }
        catch (\Throwable $e) {
          // Non-fatal — if the controller can't be resolved, just skip.
        }
      }

      // Only attach the "Print Badge Checklist" button when there is actually
      // a checklist to print. Without items the button is meaningless.
      if (
        $display
        && ($component = $display->getComponent('print_checklist'))
        && !_appointment_facilitator_badge_checklist_is_blank($entity)
      ) {
        $build['print_checklist'] = [
          '#type' => 'container',
          '#weight' => $component['weight'],
          '#attributes' => ['class' => ['print-checklist-wrapper', 'mb-3']],
          'link' => [
            '#type' => 'link',
            '#title' => t('Print Badge Checklist'),
            '#url' => Url::fromRoute('appointment_facilitator.badge_print_checklist', ['taxonomy_term' => $entity->id()]),
            '#attributes' => [
              'class' => ['btn', 'btn-outline-primary', 'btn-sm', 'd-print-none'],
              'target' => '_blank',
            ],
          ],
        ];
      }
    }
    return;
  }

  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }

  if ($entity instanceof NodeInterface) {
    _appointment_facilitator_build_node_view($build, $entity, is_string($view_mode) ? $view_mode : NULL);
  }
}

/**
 * Replaces the default multi-value string output with a readable checklist.
 */
function _appointment_facilitator_format_badge_checklist(array &$build, TermInterface $term): void {
  if (
    !isset($build['field_badge_checklist_items'])
    || !$term->hasField('field_badge_checklist_items')
    || $term->get('field_badge_checklist_items')->isEmpty()
  ) {
    return;
  }

  $items = [];
  foreach ($term->get('field_badge_checklist_items') as $item) {
    $text = _appointment_facilitator_clean_checklist_item((string) $item->value, $term->label());
    if ($text === '') {
      continue;
    }

    $items[] = [
      '#markup' => '<span class="badge-checklist-item__box" aria-hidden="true"></span><span class="badge-checklist-item__text">' . Html::escape($text) . '</span>',
    ];
  }

  if ($items === []) {
    $build['field_badge_checklist_items'] = ['#access' => FALSE];
    return;
  }

  $build['field_badge_checklist_items'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['badge-checklist-items']],
    'items' => [
      '#theme' => 'item_list',
      '#list_type' => 'ul',
      '#items' => $items,
      '#attributes' => ['class' => ['badge-checklist-list']],
      '#wrapper_attributes' => ['class' => ['badge-checklist-list-wrapper']],
    ],
    'style' => [
      '#type' => 'inline_template',
      '#template' => '
        <style>
          .badge-checklist-list {
            list-style: none;
            margin: 0;
            padding: 0;
          }
          .badge-checklist-list li {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin: 0 0 0.7rem;
            padding: 0.65rem 0.85rem;
            border: 1px solid #d9dee5;
            border-radius: 0.65rem;
            background: #fff;
          }
          .badge-checklist-item__box {
            display: inline-block;
            width: 1.1rem;
            height: 1.1rem;
            min-width: 1.1rem;
            margin-top: 0.15rem;
            border: 2px solid #5f6f52;
            border-radius: 0.25rem;
            background: #f7faf7;
          }
          .badge-checklist-item__text {
            display: inline-block;
            line-height: 1.45;
          }
        </style>',
    ],
  ];
}

/**
 * Populates the mh_badge_user_status / mh_badge_user_eligibility pseudo-fields
 * for a badges term, when the active view display has them enabled.
 *
 * Implementation lives in the BadgeUserStatusResolver service; this just
 * renders the small pill markup the embedded compliance strip and the card
 * view mode display. The full status banner is a separate block plugin.
 */
function _appointment_facilitator_attach_badge_status_pseudo_fields(array &$build, TermInterface $term, EntityViewDisplayInterface $display): void {
  $wants_status = (bool) $display->getComponent('mh_badge_user_status');
  $wants_eligibility = (bool) $display->getComponent('mh_badge_user_eligibility');
  if (!$wants_status && !$wants_eligibility) {
    return;
  }

  /** @var \Drupal\appointment_facilitator\Service\BadgeUserStatusResolver $resolver */
  $resolver = \Drupal::service('appointment_facilitator.badge_user_status');
  $current_user = \Drupal::currentUser();
  $resolved = $resolver->resolve((int) $current_user->id(), $term);
  $state = $resolved['state'];

  $cache = CacheableMetadata::createFromRenderArray($build);
  $cache->addCacheContexts(['user']);
  $cache->addCacheTags($resolved['cache_tags']);
  $cache->applyTo($build);

  if ($wants_status) {
    [$status_label, $status_tone] = _appointment_facilitator_badge_status_pill_text($state);
    // A null label means we deliberately suppress the pill for this state
    // (e.g. "not started" — the CTA banner below tells the story).
    if ($status_label !== NULL) {
      $component = $display->getComponent('mh_badge_user_status');
      $build['mh_badge_user_status'] = [
        '#type' => 'container',
        '#weight' => $component['weight'] ?? -10,
        '#attributes' => [
          'class' => [
            'mh-badge-status-pill',
            'mh-badge-status-pill--' . str_replace('_', '-', $state),
            'mh-badge-status-pill--tone-' . $status_tone,
          ],
          'data-state' => $state,
        ],
        'label' => [
          '#markup' => '<span class="mh-badge-status-pill__label">' . Html::escape((string) $status_label) . '</span>',
        ],
      ];
    }
  }

  if ($wants_eligibility) {
    [$eligibility_label, $eligibility_tone, $eligibility_glyph] = _appointment_facilitator_badge_eligibility_text($state, $term);
    $component = $display->getComponent('mh_badge_user_eligibility');

    // Make the marker a real link to the badge page. For "quiz_needed"
    // (member hasn't started) we render the brand-red primary CTA variant
    // so it reads as the obvious next action on a tool page embed.
    $classes = [
      'mh-badge-eligibility',
      'mh-badge-eligibility--tone-' . $eligibility_tone,
    ];
    if ($state === 'quiz_needed') {
      $classes[] = 'mh-badge-eligibility--start';
    }

    $badge_href = '';
    try {
      $badge_href = $term->toUrl()->toString();
    }
    catch (\Throwable) {
      // No URL (term unsaved?) — fall through and render a div.
    }

    $inner_markup = '<span class="mh-badge-eligibility__glyph" aria-hidden="true">'
      . Html::escape($eligibility_glyph)
      . '</span><span class="mh-badge-eligibility__label">'
      . Html::escape((string) $eligibility_label)
      . '</span>';

    if ($badge_href !== '') {
      $build['mh_badge_user_eligibility'] = [
        '#type' => 'html_tag',
        '#tag' => 'a',
        '#weight' => $component['weight'] ?? -9,
        '#value' => $inner_markup,
        '#attributes' => [
          'href' => $badge_href,
          'class' => $classes,
          'data-state' => $state,
          'aria-label' => (string) $eligibility_label,
        ],
      ];
    }
    else {
      $build['mh_badge_user_eligibility'] = [
        '#type' => 'container',
        '#weight' => $component['weight'] ?? -9,
        '#attributes' => [
          'class' => $classes,
          'data-state' => $state,
          'aria-label' => (string) $eligibility_label,
        ],
        'content' => ['#markup' => $inner_markup],
      ];
    }
  }
}

/**
 * Maps a resolver state to [pill label, tone].
 *
 * The not-started state intentionally returns NULL — the embedded CTA
 * banner below the pill handles that case, so showing both is redundant.
 */
function _appointment_facilitator_badge_status_pill_text(string $state): array {
  return match ($state) {
    'active' => [t('Active'), 'success'],
    'pending' => [t('Pending checkout'), 'progress'],
    'quiz_needed' => [NULL, 'progress'],
    'prereqs_missing' => [t('Prereqs missing'), 'blocked'],
    'docs_required' => [t('Docs required'), 'blocked'],
    'suspended' => [t('Suspended'), 'warning'],
    'expired' => [t('Expired'), 'warning'],
    'anonymous' => [t('Log in to see status'), 'neutral'],
    default => [t('Not started'), 'neutral'],
  };
}

/**
 * Maps a resolver state to [eligibility label, tone, glyph].
 *
 * For the "quiz_needed" state we tailor wording to the badge's checkout
 * requirement so the embed on a tool page sends members to the badge page
 * for learning resources (video, manual, requirements) rather than
 * pushing them straight to the quiz.
 */
function _appointment_facilitator_badge_eligibility_text(string $state, ?TermInterface $term = NULL): array {
  $checkout = '';
  if (
    $term
    && $term->hasField('field_badge_checkout_requirement')
    && !$term->get('field_badge_checkout_requirement')->isEmpty()
  ) {
    $checkout = strtolower(trim((string) $term->get('field_badge_checkout_requirement')->value));
  }

  switch ($state) {
    case 'active':
      return [t('You have this badge'), 'success', '✓'];

    case 'pending':
      return [t('Schedule a facilitator session — open badge page'), 'progress', '→'];

    case 'quiz_needed':
      if ($checkout === 'class') {
        $label = t('Start this badge — workshop or documentation required');
      }
      else {
        $label = t('Start this badge');
      }
      return [$label, 'progress', '→'];

    case 'prereqs_missing':
      return [t('Open badge page — earn prerequisite badges first'), 'blocked', '⚠'];

    case 'docs_required':
      return [t('Open badge page — submit training documentation'), 'blocked', '⚠'];

    case 'suspended':
      return [t('Suspended — contact staff'), 'warning', '⛔'];

    case 'expired':
      return [t('Expired — open badge page to renew'), 'warning', '⛔'];

    case 'anonymous':
      return [t('Log in to check eligibility'), 'neutral', '?'];

    default:
      return [t('Open badge page for details'), 'neutral', '·'];
  }
}

/**
 * Removes duplicate title rows and stray export artifacts from checklist text.
 */
function _appointment_facilitator_clean_checklist_item(string $text, string $badge_title): string {
  $text = preg_replace('/^\x{FEFF}/u', '', trim($text)) ?? trim($text);
  if ($text === '') {
    return '';
  }

  return trim(strcasecmp($text, trim($badge_title)) === 0 ? '' : $text);
}

/**
 * Implements hook_preprocess_HOOK() for views_view_unformatted.
 *
 * Attaches per-card data attributes to each row of the /badges directory so
 * a small JS filter can hide/show cards without a round-trip. We also drop
 * a filter-bar header in via hook_views_pre_render() below.
 */
/**
 * Implements hook_preprocess_views_view().
 *
 * Adds a stable id to the event_upcoming_badging EVA so the badge status
 * banner can deep-link from its "upcoming classes listed below" text.
 */
function appointment_facilitator_preprocess_views_view(array &$variables): void {
  $view = $variables['view'] ?? NULL;
  if (!$view || $view->id() !== 'event_upcoming_badging') {
    return;
  }
  $variables['attributes']['id'] = 'earn-badge-at-event';
}

function appointment_facilitator_preprocess_views_view_unformatted(array &$variables): void {
  $view = $variables['view'] ?? NULL;
  if (!$view || $view->id() !== 'badges') {
    return;
  }

  $area_map = \Drupal::hasService('appointment_facilitator.badge_area_mapper')
    ? \Drupal::service('appointment_facilitator.badge_area_mapper')->getAreaMap()
    : [];

  $resolver = \Drupal::hasService('appointment_facilitator.badge_user_status')
    ? \Drupal::service('appointment_facilitator.badge_user_status')
    : NULL;
  $uid = (int) \Drupal::currentUser()->id();

  foreach ($variables['rows'] as $i => $row) {
    $term = $view->result[$i]->_entity ?? NULL;
    if (!$term instanceof TermInterface || $term->bundle() !== 'badges') {
      continue;
    }
    $tid = (int) $term->id();

    $checkout = '';
    if ($term->hasField('field_badge_checkout_requirement') && !$term->get('field_badge_checkout_requirement')->isEmpty()) {
      $checkout = strtolower(trim((string) $term->get('field_badge_checkout_requirement')->value));
    }

    $state = 'anonymous';
    if ($resolver) {
      $state = (string) ($resolver->resolve($uid, $term)['state'] ?? 'anonymous');
    }

    $areas = $area_map[$tid] ?? [];

    if (isset($variables['rows'][$i]['attributes'])) {
      $variables['rows'][$i]['attributes']->setAttribute('data-badge-tid', $tid);
      $variables['rows'][$i]['attributes']->setAttribute('data-areas', implode(',', $areas));
      $variables['rows'][$i]['attributes']->setAttribute('data-checkout', $checkout);
      $variables['rows'][$i]['attributes']->setAttribute('data-state', $state);
      $variables['rows'][$i]['attributes']->addClass('badge-card-row');
    }
  }

  // Cache by user — state is per-user.
  $variables['#cache']['contexts'][] = 'user';
}

/**
 * Builds the /badges filter-bar markup and attaches the JS library that
 * wires its select controls to row visibility. Called from the existing
 * `appointment_facilitator_views_pre_render()` hook.
 */
function _appointment_facilitator_attach_badges_filter_bar(ViewExecutable $view): void {
  /** @var \Drupal\taxonomy\TermStorageInterface $term_storage */
  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  // loadTree returns terms in hierarchical order (parent first, then each
  // parent's descendants) with a `depth` property for indentation.
  $tree = $term_storage->loadTree('area_of_interest', 0, NULL, FALSE);

  $area_options_html = '';
  foreach ($tree as $area) {
    $depth = (int) ($area->depth ?? 0);
    // Indent children with a hairspace-padded em-dash, e.g.
    //   "3D Fabrication" → top-level
    //   "— CNC Routing"  → child
    //   "—— Detail"      → grandchild
    $indent = $depth > 0 ? str_repeat('—', $depth) . ' ' : '';
    $area_options_html .= '<option value="' . (int) $area->tid . '">'
      . Html::escape($indent . $area->name)
      . '</option>';
  }

  $logged_in = \Drupal::currentUser()->isAuthenticated();
  $state_options = '<option value="">All states</option>';
  if ($logged_in) {
    $state_options .= '<option value="mine">Badges I have</option>'
      . '<option value="pending">In progress</option>'
      . '<option value="available">Available to start</option>'
      . '<option value="blocked">Blocked (prereqs/docs)</option>';
  }

  $checkout_options = '<option value="">Any requirement</option>'
    . '<option value="no">Quiz only (no checkout)</option>'
    . '<option value="yes">In-person checkout</option>'
    . '<option value="class">Workshop or documentation</option>';

  $callout_html = _appointment_facilitator_build_badges_directory_callout();

  $html = $callout_html
    . '<div class="badges-filter-bar" data-badges-filter>'
    . '<label class="badges-filter-bar__field"><span>Area</span>'
    . '<select data-filter="area"><option value="">All areas</option>' . $area_options_html . '</select></label>'
    . '<label class="badges-filter-bar__field"><span>Requirement</span>'
    . '<select data-filter="checkout">' . $checkout_options . '</select></label>'
    . '<label class="badges-filter-bar__field"><span>Status</span>'
    . '<select data-filter="state">' . $state_options . '</select></label>'
    . '<button type="button" class="badges-filter-bar__reset" data-filter-reset>Reset</button>'
    . '<p class="badges-filter-bar__count" data-filter-count></p>'
    . '</div>';

  $view->element['#attached']['library'][] = 'appointment_facilitator/badges_filter';
  // The callout is personalized, so make sure the view varies on user + has
  // the right invalidation tags.
  $view->element['#cache']['contexts'][] = 'user';
  $view->element['#cache']['tags'][] = 'node_list:badge_request';
  $view->element['#cache']['tags'][] = 'user_list';
  // Mark the markup safe so Drupal's XSS filter doesn't strip <select>,
  // <option>, etc.
  $view->element['#prefix'] = Markup::create(
    ($view->element['#prefix'] ?? '') . $html
  );
}

/**
 * Implements hook_preprocess_HOOK() for html.
 *
 * Adds a `.path-taxonomy--badges` body class on badge term pages so we
 * can scope CSS overrides — chiefly hiding Drupal's default-page node
 * listing (course/event nodes tagged with the badge) which renders as
 * raw teasers at the bottom and isn't useful on badge pages.
 */
function appointment_facilitator_preprocess_html(array &$variables): void {
  $route_match = \Drupal::routeMatch();
  if ($route_match->getRouteName() !== 'entity.taxonomy_term.canonical') {
    return;
  }
  $term = $route_match->getParameter('taxonomy_term');
  if (!$term instanceof TermInterface || $term->bundle() !== 'badges') {
    return;
  }
  $variables['attributes']['class'][] = 'path-taxonomy--badges';
}

/**
 * Implements hook_preprocess_HOOK() for page_title.
 *
 * Adds "Badge" suffix to taxonomy_term:badges pages so a page about
 * "Panel Saw" the badge doesn't read identically to the "Panel Saw" tool
 * page. Done at the title-block preprocess level so the head <title> and
 * the visible page heading both pick it up.
 */
function appointment_facilitator_preprocess_page_title(array &$variables): void {
  $route_match = \Drupal::routeMatch();
  if ($route_match->getRouteName() !== 'entity.taxonomy_term.canonical') {
    return;
  }
  $term = $route_match->getParameter('taxonomy_term');
  if (!$term instanceof TermInterface || $term->bundle() !== 'badges') {
    return;
  }
  $label = (string) $term->label();
  $variables['title'] = stripos($label, 'badge') !== FALSE
    ? $label
    : t('@name Badge', ['@name' => $label]);

  // Associated tools sit at the very top — they're decision context
  // about the badge, not a step in earning it. Rendered above the hero
  // image and title so members can see what hardware this unlocks
  // before they read anything else.
  $tools_render = _appointment_facilitator_build_related_tools($term);
  if (!empty($tools_render)) {
    $variables['title_prefix']['badge_related_tools'] = $tools_render + ['#weight' => -200];
  }

  // Promote the badge image above the title. The original field render
  // (further down in the entity view) is suppressed in
  // appointment_facilitator_entity_view() so this is the only place it
  // appears, and the layout reads as a centered hero (image → title).
  if ($term->hasField('field_member_badge_image') && !$term->get('field_member_badge_image')->isEmpty()) {
    $image = $term->get('field_member_badge_image')->view([
      'label' => 'hidden',
      'type' => 'image',
      'settings' => [
        'image_style' => 'medium',
        'image_link' => '',
        'image_loading' => ['attribute' => 'eager'],
      ],
    ]);
    $variables['title_prefix']['badge_hero_image'] = [
      '#type' => 'container',
      '#weight' => -100,
      '#attributes' => ['class' => ['badge-hero-image']],
      'image' => $image,
    ];
    $variables['#cache']['tags'] = array_merge($variables['#cache']['tags'] ?? [], $term->getCacheTags());
  }
}

/**
 * Implements hook_field_group_pre_render_alter().
 *
 * Suppresses the `group_checklist` accordion on a badge term page when the
 * badge has no checklist items — otherwise field_group renders an empty
 * "Badge Checklist" fieldset with just the "Complete these items to earn
 * the badge." placeholder and no content beneath it.
 *
 * 95 of 144 badges have empty checklists, so this affects most of the
 * directory.
 */
function appointment_facilitator_field_group_pre_render_alter(array &$element, $group, &$rendering_object): void {
  if (
    !isset($group->group_name)
    || !isset($group->entity_type)
    || $group->entity_type !== 'taxonomy_term'
    || !isset($group->bundle)
    || $group->bundle !== 'badges'
  ) {
    return;
  }

  $term = $rendering_object['#taxonomy_term'] ?? NULL;
  if (!$term instanceof TermInterface) {
    return;
  }

  if ($group->group_name === 'group_checklist') {
    if (_appointment_facilitator_badge_checklist_is_blank($term)) {
      $element['#access'] = FALSE;
    }
    return;
  }

  if ($group->group_name === 'group_prerequisite') {
    // The status banner stepper already communicates "where you are" and
    // the banner body lists the specific prerequisite badges the viewer
    // still needs. Repeating that as a body-region card duplicated the
    // information and dropped a chunky "Prerequisite" box halfway down
    // the page even for members who'd already cleared the gate.
    $element['#access'] = FALSE;
    return;
  }

  if ($group->group_name === 'group_timestamps') {
    // The timestamps list is often 15-20 entries — long enough to push
    // the quiz button below the fold. Wrap as a closed <details> so
    // members can expand it on demand. The field_group module renders
    // this as a fieldset by default; rewriting the element type here is
    // a smaller change than altering the view-display config.
    $element['#type'] = 'details';
    $element['#open'] = FALSE;
    $element['#title'] = (string) t('Timestamps');
    return;
  }

  if ($group->group_name === 'group_quiz') {
    // Tell members up front what they're about to do — "X questions"
    // makes the Take quiz button less of a leap of faith. Also gate the
    // quiz link itself on the materials-reviewed flag: if the badge has
    // a video and the member hasn't ticked "I've reviewed the materials",
    // replace the live link with a clear "review first" hint so the
    // dependency is explicit rather than just stylistic on the stepper.
    if (!$term->hasField('field_badge_quiz_reference') || $term->get('field_badge_quiz_reference')->isEmpty()) {
      return;
    }
    $quiz = $term->get('field_badge_quiz_reference')->entity;
    if (!$quiz || !method_exists($quiz, 'id')) {
      return;
    }

    $count = (int) \Drupal::database()
      ->select('quiz_question_relationship', 'r')
      ->condition('r.quiz_id', (int) $quiz->id())
      ->condition('r.question_status', 1)
      ->countQuery()
      ->execute()
      ->fetchField();

    if ($count > 0) {
      $element['appointment_facilitator_quiz_meta'] = [
        '#type' => 'inline_template',
        '#template' => '<p class="badge-quiz-meta">{{ count_label }} &middot; <span class="badge-quiz-meta__hint">{{ hint }}</span></p>',
        '#context' => [
          'count_label' => \Drupal::translation()->formatPlural($count, '1 question', '@count questions'),
          'hint' => t('You can retake if you don\'t pass.'),
        ],
        '#weight' => -10,
      ];
    }

    // Review-gate: if there's a video to watch but the member hasn't
    // self-attested to watching it, swap the active quiz link for a
    // disabled-button-plus-hint pair. We rely on the same user.data
    // flag the stepper reads.
    $has_video = $term->hasField('field_badge_video') && !$term->get('field_badge_video')->isEmpty();
    $uid = (int) \Drupal::currentUser()->id();
    $watched = $has_video
      ? \Drupal\appointment_facilitator\Form\BadgeVideoWatchedForm::isWatched(\Drupal::service('user.data'), $uid, (int) $term->id())
      : TRUE;
    $is_admin = \Drupal::currentUser()->hasPermission('administer nodes');

    if ($has_video && !$watched && !$is_admin && $uid > 0) {
      // Hide the actual quiz link and inject a disabled-button surrogate
      // so the visual remains balanced (quiz card always has a CTA-shape
      // element). Anonymous viewers fall through unchanged — they see
      // the link, since they'd be sent to /user/login first anyway.
      if (isset($element['field_badge_quiz_reference'])) {
        $element['field_badge_quiz_reference']['#access'] = FALSE;
      }
      $element['appointment_facilitator_quiz_locked'] = [
        '#type' => 'inline_template',
        '#template' => <<<TWIG
<div class="badge-quiz-locked">
  <span class="btn btn-secondary btn-sm disabled badge-quiz-locked__btn" aria-disabled="true" role="button" title="{{ tooltip }}">{{ label }}</span>
  <p class="badge-quiz-locked__hint">{{ hint }}</p>
</div>
TWIG,
        '#context' => [
          'label' => t('Take quiz'),
          'tooltip' => t('Mark the materials as reviewed first.'),
          'hint' => t('The quiz unlocks once you mark the materials above as reviewed.'),
        ],
        '#weight' => 5,
      ];
      // The user-state-driven swap needs the per-user cache context so
      // anon/auth/different members don't share a cached fragment.
      $element['#cache']['contexts'][] = 'user';
      $element['#cache']['max-age'] = 0;
    }
    return;
  }

  if ($group->group_name === 'group_video') {
    // The fieldset is the "review materials" hub on the badge page, not
    // just a video container — relabel so members understand that
    // checklists, manuals, and transcripts also live here.
    $element['#title'] = (string) t('Review materials');

    // Pull any manuals attached to the associated tool pages so members
    // have all the prep material in one place. The manuals are file
    // entities on `field_manuals` of the related item nodes. The helper
    // returns an empty array for anonymous viewers — vendor manuals
    // aren't meant to be publicly indexable.
    $manuals = _appointment_facilitator_collect_tool_manuals($term);
    // Per-user gate above — make sure the cache reflects that.
    $element['#cache']['contexts'][] = 'user.roles:authenticated';
    if (!empty($manuals)) {
      $element['appointment_facilitator_tool_manuals'] = [
        '#type' => 'container',
        '#weight' => 5,
        '#attributes' => ['class' => ['badge-tool-manuals']],
        'heading' => [
          '#type' => 'html_tag',
          '#tag' => 'h3',
          '#attributes' => ['class' => ['h5', 'badge-tool-manuals__heading']],
          '#value' => t('Tool manuals'),
        ],
        'intro' => [
          '#markup' => '<p class="badge-tool-manuals__intro">' . t('From the associated tool pages — members-only prep material.') . '</p>',
        ],
        'list' => $manuals,
      ];
    }
    return;
  }

  if ($group->group_name === 'group_documentation') {
    // For badges where training documentation is offered as a path (the
    // banner asks the member to "Submit documentation"), the actual link
    // sits in group_documentation at weight=5 — far below the banner that
    // referenced it. Pull it up so the link is reachable without scrolling.
    // Detection: the badge has a documentation node reference AND uses a
    // checkout requirement that surfaces the docs path (class, or yes
    // when the gate evaluator routes to STATE_DOCS_REQUIRED).
    if (!empty($term) && $term->hasField('field_training_documentation') && !$term->get('field_training_documentation')->isEmpty()) {
      $element['#weight'] = 0.5;
    }
    return;
  }

  if ($group->group_name === 'group_checkout' || $group->group_name === 'group_complete_checkout') {
    _appointment_facilitator_replace_checkout_group_with_schedule($element, $term);
    return;
  }
}

/**
 * Inside the Facilitator Checkout group, replace the per-slot facilitator
 * cards with the calendar-grid schedule used on /badges/complete, and hide
 * the now-redundant raw badge_issuer username lists.
 *
 * The grid renders even when the prerequisite gate would otherwise hide
 * scheduling — members on the path to the badge benefit from seeing real
 * facilitator availability while planning, and the appointment form / quiz
 * flow handles enforcement when they actually try to book. A clear banner
 * inside the grid section explains what they need to finish first.
 *
 * Tool-offline state still suppresses the grid: scheduling is genuinely
 * impossible until the tool is back, so the offline notice stands alone.
 */
function _appointment_facilitator_replace_checkout_group_with_schedule(array &$element, TermInterface $term): void {
  // Short-circuit when this badge auto-issues after the quiz — there's no
  // checkout to book, and enforce_badge_page_flow has already added the
  // "No facilitator checkout required" notice elsewhere on the page.
  // Hiding the entire group prevents the field_group from rendering an
  // empty "Facilitator Checkout" fieldset.
  if (
    $term->hasField('field_badge_checkout_requirement')
    && !$term->get('field_badge_checkout_requirement')->isEmpty()
    && strtolower(trim((string) $term->get('field_badge_checkout_requirement')->value)) === 'no'
  ) {
    $element['#access'] = FALSE;
    return;
  }

  // The plain entity_reference_label list of facilitator usernames is
  // redundant with the calendar grid we're about to render below.
  foreach (['field_badge_issuer', 'field_badge_issuer_on_request'] as $key) {
    if (isset($element[$key])) {
      $element[$key]['#access'] = FALSE;
    }
  }

  // The legacy EVA renders one card per slot per facilitator — visually
  // noisy and duplicative of the calendar grid we're about to inject.
  $eva_key = 'facilitator_schedules_facilitator_schedule_tool_eva';
  if (isset($element[$eva_key])) {
    $element[$eva_key]['#access'] = FALSE;
  }

  $tool_offline = FALSE;
  if (\Drupal::hasService('appointment_facilitator.badge_gate')) {
    /** @var \Drupal\appointment_facilitator\Service\BadgePrerequisiteGate $gate */
    $gate = \Drupal::service('appointment_facilitator.badge_gate');
    $tool_offline = $gate->isBadgeOffline($term);
  }

  // Tag the group so the gate-CSS hider exempts it — without this class,
  // members who haven't started the badge would have the whole group_checkout
  // fieldset hidden by display:none, swallowing the grid we're rendering.
  $element['#attributes']['class'][] = 'appointment-facilitator-has-schedule-grid';

  if ($tool_offline) {
    $element['appointment_facilitator_schedule_table'] = [
      '#weight' => -50,
      '#type' => 'container',
      '#attributes' => ['class' => ['appointment-facilitator-schedule-empty', 'alert', 'alert-warning']],
      'message' => [
        '#markup' => '<p>' . t('This tool is currently offline for maintenance. Booking is paused until it returns. Check Slack #facilitator-hours for an update.') . '</p>',
      ],
    ];
    return;
  }

  $is_gated = _appointment_facilitator_checkout_group_gate_blocked($term);

  try {
    /** @var \Drupal\appointment_facilitator\Controller\BadgeNextStepsController $controller */
    $controller = \Drupal::classResolver()->getInstanceFromDefinition(BadgeNextStepsController::class);
  }
  catch (\Throwable $e) {
    return;
  }

  $table = $controller->buildScheduleTableForBadgeTerm($term, $is_gated);

  if (empty($table)) {
    // Either the badge has no rostered facilitators, or every rostered
    // facilitator currently has no published hours / is on break this week.
    // Either way, point members to /facilitator/schedules where they'll see
    // the full roster (greyed entries included) so they can decide who to
    // ping on Slack.
    $element['appointment_facilitator_schedule_table'] = [
      '#weight' => -50,
      '#type' => 'container',
      '#attributes' => ['class' => ['appointment-facilitator-schedule-empty', 'alert', 'alert-info']],
      'message' => [
        '#markup' => '<p>'
          . t('No facilitator has published checkout times in the next two weeks. See the <a href="@url">facilitator schedule</a> for who is normally on the schedule (including anyone on break), then ping them on Slack #facilitator-hours.',
            ['@url' => '/facilitator/schedules'])
          . '</p>',
      ],
    ];
    return;
  }

  $grid_classes = ['appointment-facilitator-schedule-grid'];
  if ($is_gated) {
    $grid_classes[] = 'appointment-facilitator-schedule-grid--gated';
    $intro_markup = '<div class="appointment-facilitator-schedule-intro appointment-facilitator-schedule-intro--gated">'
      . '<strong>' . t('Complete the requirements above first.') . '</strong> '
      . t('You can preview facilitator availability below — but booking is locked until you finish the prerequisites and pass the quiz on this badge page.')
      . '</div>';
  }
  else {
    $intro_markup = '<p class="appointment-facilitator-schedule-intro">'
      . t('Pick a checkout time below. All bookings flow through the appointment system — please do not arrange checkouts via Slack.')
      . '</p>';
  }

  $element['appointment_facilitator_schedule_table'] = [
    '#weight' => -50,
    '#type' => 'container',
    '#attributes' => ['class' => $grid_classes],
    'intro' => [
      '#markup' => $intro_markup,
    ],
    'table' => $table,
  ];
}

/**
 * Returns TRUE when the prerequisite gate (or tool-offline state) has wiped
 * the checkout group, so we should not re-inject scheduling.
 */
function _appointment_facilitator_checkout_group_gate_blocked(TermInterface $term): bool {
  if (!\Drupal::hasService('appointment_facilitator.badge_gate')) {
    return FALSE;
  }
  /** @var \Drupal\appointment_facilitator\Service\BadgePrerequisiteGate $gate */
  $gate = \Drupal::service('appointment_facilitator.badge_gate');

  if ($gate->isBadgeOffline($term)) {
    return TRUE;
  }

  $account = \Drupal::currentUser();
  $uid = (int) $account->id();
  if ($uid <= 0 || $account->hasPermission('administer nodes')) {
    return FALSE;
  }

  // Use the resolver's state as the source of truth: only ACTIVE (already
  // has the badge) or PENDING (passed quiz, awaiting checkout) should see
  // an unlocked schedule. Earlier code only checked prereqs+docs and let
  // members book a checkout slot before passing the quiz — which produced
  // the bug surfaced on fabricator-sewing-machine where Schedule buttons
  // were live while the quiz was still required.
  //
  // Additional gate: when the badge requires training documentation, the
  // schedule stays blocked in PENDING until the documentation is approved.
  // (Members on docs-required badges who pass the quiz reach PENDING with
  // documentation_status='not_submitted' or 'pending_review'; only
  // 'approved' should unlock scheduling.)
  if (\Drupal::hasService('appointment_facilitator.badge_user_status')) {
    /** @var \Drupal\appointment_facilitator\Service\BadgeUserStatusResolver $resolver */
    $resolver = \Drupal::service('appointment_facilitator.badge_user_status');
    $resolved = $resolver->resolve($uid, $term);
    $state = $resolved['state'] ?? '';
    if (in_array($state, ['active', 'pending'], TRUE)) {
      $docs_status = $resolved['documentation_status'] ?? 'not_required';
      if ($docs_status !== 'not_required' && $docs_status !== 'approved') {
        return TRUE;
      }
      return FALSE;
    }
    return TRUE;
  }

  // Fallback to legacy gate when the resolver isn't available.
  $result = $gate->evaluate($uid, $term);
  return is_array($result) && empty($result['allowed']);
}

/**
 * Adds a small "badge popularity" stats panel to the badge term render.
 *
 * Shows what percent of active makers hold this badge plus its rank among
 * all badges with at least one holder. Lightweight; values are cached for
 * a day inside the service.
 */
function _appointment_facilitator_attach_badge_popularity_stats(array &$build, TermInterface $badge): void {
  if (!\Drupal::hasService('appointment_facilitator.badge_popularity')) {
    return;
  }

  /** @var \Drupal\appointment_facilitator\Service\BadgePopularityStats $service */
  $service = \Drupal::service('appointment_facilitator.badge_popularity');
  $stats = $service->getStats($badge);

  if (($stats['holders'] ?? 0) <= 0) {
    return;
  }

  $facts = [];
  $facts[] = t('@n members hold this badge', ['@n' => $stats['holders']]);
  if (!empty($stats['percent_of_active'])) {
    $facts[] = t('@pct% of active makers', ['@pct' => $stats['percent_of_active']]);
  }

  $build['appointment_facilitator_badge_popularity'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['badge-popularity-stats']],
    '#weight' => -50,
    'heading' => [
      '#type' => 'html_tag',
      '#tag' => 'h3',
      '#attributes' => ['class' => ['badge-popularity-stats__heading']],
      '#value' => t('Badge popularity'),
    ],
    'facts' => [
      '#theme' => 'item_list',
      '#items' => array_map(fn ($f) => ['#markup' => (string) $f], $facts),
      '#attributes' => ['class' => ['badge-popularity-stats__list']],
    ],
    '#cache' => [
      'tags' => ['node_list:badge_request', 'taxonomy_term:' . $badge->id()],
    ],
  ];
}

/**
 * Renders the BadgeStatusBannerBlock content inline at the very top of the
 * badge term render array (just under the page title), instead of in the
 * pre_content region above the title. Pairs with the BadgePopularityStats
 * block which now sits in pre_content where the banner used to live —
 * order on the page becomes: stats → title → next-step banner → content.
 *
 * The block is invoked programmatically rather than placed at content,
 * because Drupal's block layout doesn't have a "between title and content"
 * region in this theme — inline rendering is the cleanest way to anchor
 * the banner to the badge term entity itself.
 */
function _appointment_facilitator_attach_badge_next_step_banner(array &$build, TermInterface $badge): void {
  try {
    $block_manager = \Drupal::service('plugin.manager.block');
    /** @var \Drupal\appointment_facilitator\Plugin\Block\BadgeStatusBannerBlock $block */
    $block = $block_manager->createInstance('appointment_facilitator_badge_status_banner', []);
    $rendered = $block->build();
  }
  catch (\Throwable $e) {
    return;
  }

  if (empty($rendered)) {
    return;
  }

  $build['appointment_facilitator_next_step_banner'] = [
    '#weight' => -200,
    'banner' => $rendered,
  ];
  $build['#cache']['contexts'][] = 'user';
}

/**
 * Replaces the plain entity_reference_label rendering of
 * `field_badge_prerequisite` with a card-style list that shows the viewer's
 * progress against each prereq:
 *   - Earned   → green pill "Earned ✓", no CTA needed
 *   - Pending  → amber pill "In progress", link to that badge page
 *   - Missing  → red pill "Not earned — start here", link to that badge page
 *
 * Mirrors the way tool pages already surface this — without it, a member on
 * a gated badge page sees the prereq's name but no signal about whether
 * they need to act on it, which is the exact "confused and stuck" failure
 * the user flagged.
 */
function _appointment_facilitator_decorate_prerequisite_field(array &$build, TermInterface $badge): void {
  if (
    !$badge->hasField('field_badge_prerequisite')
    || $badge->get('field_badge_prerequisite')->isEmpty()
    || empty($build['field_badge_prerequisite'])
  ) {
    return;
  }

  $prereq_terms = $badge->get('field_badge_prerequisite')->referencedEntities();
  if (!$prereq_terms) {
    return;
  }

  $resolver = NULL;
  $uid = (int) \Drupal::currentUser()->id();
  if ($uid > 0 && \Drupal::hasService('appointment_facilitator.badge_user_status')) {
    $resolver = \Drupal::service('appointment_facilitator.badge_user_status');
  }

  $items = [];
  foreach ($prereq_terms as $prereq) {
    if (!$prereq instanceof TermInterface) {
      continue;
    }
    $url = '/taxonomy/term/' . (int) $prereq->id();
    try {
      $url = $prereq->toUrl()->toString();
    }
    catch (\Throwable) {
    }

    [$pill_label, $pill_tone, $cta_label] = _appointment_facilitator_prerequisite_status_meta($prereq, $resolver, $uid);

    $items[] = [
      '#type' => 'container',
      '#attributes' => ['class' => ['badge-prereq-card', 'badge-prereq-card--tone-' . $pill_tone]],
      'name' => [
        '#type' => 'html_tag',
        '#tag' => 'a',
        '#value' => $prereq->label(),
        '#attributes' => [
          'href' => $url,
          'class' => ['badge-prereq-card__name'],
        ],
      ],
      'pill' => [
        '#type' => 'html_tag',
        '#tag' => 'span',
        '#attributes' => ['class' => ['badge-prereq-card__pill', 'badge-prereq-card__pill--' . $pill_tone]],
        '#value' => $pill_label,
      ],
      'cta' => $cta_label !== NULL ? [
        '#type' => 'html_tag',
        '#tag' => 'a',
        '#value' => $cta_label,
        '#attributes' => [
          'href' => $url,
          'class' => ['badge-prereq-card__cta'],
        ],
      ] : ['#access' => FALSE],
    ];
  }

  if (!$items) {
    return;
  }

  // The field group (group_prerequisite) renders its own "Prerequisite"
  // legend — we don't add a second label here. The original field render
  // had `label: inline` which the field-group fieldset already collapses
  // visually, but the entity_reference_label formatter still emits an
  // inline label span; replacing the whole field with a container drops
  // that span and avoids the double-heading.
  $weight = $build['field_badge_prerequisite']['#weight'] ?? 0;
  $build['field_badge_prerequisite'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['field', 'field--name-field-badge-prerequisite', 'badge-prereq-list']],
    '#weight' => $weight,
    'items' => [
      '#type' => 'container',
      '#attributes' => ['class' => ['badge-prereq-list__items']],
    ] + $items,
    '#attached' => [
      'library' => ['appointment_facilitator/badge_prereq_list'],
    ],
  ];

  // Status varies per user; don't serve a stale render to other viewers.
  $build['#cache']['contexts'][] = 'user';
  $build['#cache']['max-age'] = 0;
}

/**
 * Returns [pill label, tone, CTA label-or-NULL] for a prerequisite badge.
 *
 * Every non-active CTA points to the prereq's badge page (NOT directly to
 * the quiz), so members go through the full flow on that page — watch the
 * video, review requirements, then take the quiz — rather than skipping
 * straight to the quiz and bouncing off when they miss the framing.
 */
function _appointment_facilitator_prerequisite_status_meta(TermInterface $prereq, $resolver, int $uid): array {
  if (!$resolver || $uid <= 0) {
    return [
      (string) t('Required'),
      'muted',
      (string) t('Open this badge page →'),
    ];
  }

  $resolved = $resolver->resolve($uid, $prereq);
  $state = $resolved['state'] ?? '';
  return match ($state) {
    'active' => [
      (string) t('Earned ✓'),
      'success',
      NULL,
    ],
    'pending' => [
      (string) t('In progress'),
      'info',
      (string) t('Continue on this badge page →'),
    ],
    'quiz_needed' => [
      (string) t('Quiz pending'),
      'info',
      (string) t('Continue on this badge page →'),
    ],
    'prereqs_missing' => [
      (string) t('Blocked by prereqs'),
      'warning',
      (string) t('Open this badge page →'),
    ],
    'docs_required' => [
      (string) t('Class or docs needed'),
      'warning',
      (string) t('Open this badge page →'),
    ],
    'expired' => [
      (string) t('Expired'),
      'warning',
      (string) t('Renew on this badge page →'),
    ],
    'suspended' => [
      (string) t('Suspended'),
      'warning',
      (string) t('Open this badge page →'),
    ],
    default => [
      (string) t('Not started'),
      'danger',
      (string) t('Start on this badge page →'),
    ],
  };
}

/**
 * Builds a "where do I start?" callout for the top of the /badges directory.
 *
 * 135 badges is overwhelming on first contact. This banner gives authenticated
 * members a one-click escape to /badges/complete (their personal progress
 * page) and surfaces their badge count + rank inline as a small nudge to
 * keep going. Anonymous visitors get a generic "see your progress after
 * login" pitch instead.
 */
function _appointment_facilitator_build_badges_directory_callout(): string {
  $current_user = \Drupal::currentUser();
  $uid = (int) $current_user->id();

  // Anonymous variant — just the link, no stats.
  if (!$current_user->isAuthenticated() || $uid <= 0) {
    return '<aside class="badges-directory-callout badges-directory-callout--anon">'
      . '<div class="badges-directory-callout__body">'
      . '<p class="badges-directory-callout__lead">'
      . t('New to MakeHaven badges? Log in to see your progress and personalized recommendations.')
      . '</p>'
      . '</div>'
      . '<a class="badges-directory-callout__cta" href="/user/login?destination=/badges/complete">'
      . t('Log in →')
      . '</a>'
      . '</aside>';
  }

  // Authenticated variant — pull the same stats /badges/complete shows.
  $db = \Drupal::database();
  $door_tid = 1519;

  // My equipment-badge count.
  $q = $db->select('node__field_member_to_badge', 'm');
  $q->innerJoin('node__field_badge_status', 's', 's.entity_id = m.entity_id');
  $q->innerJoin('node__field_badge_requested', 'b', 'b.entity_id = m.entity_id');
  $q->innerJoin('node_field_data', 'n', 'n.nid = m.entity_id');
  $q->condition('n.type', 'badge_request');
  $q->condition('n.status', 1);
  $q->condition('s.field_badge_status_value', 'active');
  $q->condition('b.field_badge_requested_target_id', $door_tid, '<>');
  $q->condition('m.field_member_to_badge_target_id', $uid);
  $q->addExpression('COUNT(DISTINCT b.field_badge_requested_target_id)', 'c');
  $my_count = (int) $q->execute()->fetchField();

  // Rank: count members with strictly more equipment badges + 1.
  $sub = $db->select('node__field_member_to_badge', 'm');
  $sub->innerJoin('node__field_badge_status', 's', 's.entity_id = m.entity_id');
  $sub->innerJoin('node__field_badge_requested', 'b', 'b.entity_id = m.entity_id');
  $sub->innerJoin('node_field_data', 'n', 'n.nid = m.entity_id');
  $sub->innerJoin('user__roles', 'r', 'r.entity_id = m.field_member_to_badge_target_id');
  $sub->innerJoin('users_field_data', 'u', 'u.uid = m.field_member_to_badge_target_id');
  $sub->condition('n.type', 'badge_request');
  $sub->condition('n.status', 1);
  $sub->condition('s.field_badge_status_value', 'active');
  $sub->condition('b.field_badge_requested_target_id', $door_tid, '<>');
  $sub->condition('r.roles_target_id', 'member');
  $sub->condition('u.status', 1);
  $sub->addField('m', 'field_member_to_badge_target_id', 'uid');
  $sub->addExpression('COUNT(DISTINCT b.field_badge_requested_target_id)', 'badge_count');
  $sub->groupBy('m.field_member_to_badge_target_id');
  $rank = 1;
  $total_ranked = 0;
  foreach ($sub->execute()->fetchAll() as $row) {
    $total_ranked++;
    if ((int) $row->badge_count > $my_count) {
      $rank++;
    }
  }

  $cta_label = $my_count === 0
    ? t('Find your first badge →')
    : t('See your progress →');

  // Tiny stats strip — only render the rank fragment when the member has
  // earned at least one badge.
  $stats_parts = [];
  if ($my_count === 0) {
    $stats_parts[] = '<strong>0</strong> ' . t('equipment badges yet — pick one to start!');
  }
  elseif ($my_count === 1) {
    $stats_parts[] = '<strong>1</strong> ' . t('equipment badge');
  }
  else {
    $stats_parts[] = '<strong>' . $my_count . '</strong> ' . t('equipment badges');
  }
  if ($my_count > 0 && $total_ranked > 0) {
    $stats_parts[] = t('Rank <strong>#@rank</strong> of @total members', [
      '@rank' => $rank,
      '@total' => $total_ranked,
    ]);
  }

  $lead = $my_count === 0
    ? t('Overwhelmed by the list? Start with badges in your areas of interest.')
    : t('Pick up where you left off — your in-progress badges and recommendations are waiting.');

  return '<aside class="badges-directory-callout">'
    . '<div class="badges-directory-callout__body">'
    . '<p class="badges-directory-callout__lead">' . $lead . '</p>'
    . '<p class="badges-directory-callout__stats">' . implode(' &middot; ', $stats_parts) . '</p>'
    . '</div>'
    . '<a class="badges-directory-callout__cta" href="/badges/complete">' . $cta_label . '</a>'
    . '</aside>';
}

/**
 * Returns TRUE when every checklist item on the badge is blank/whitespace
 * after the same cleanup pass that the field display uses.
 */
function _appointment_facilitator_badge_checklist_is_blank(TermInterface $badge): bool {
  if (!$badge->hasField('field_badge_checklist_items') || $badge->get('field_badge_checklist_items')->isEmpty()) {
    return TRUE;
  }
  $title = (string) $badge->label();
  foreach ($badge->get('field_badge_checklist_items')->getValue() as $item) {
    $clean = _appointment_facilitator_clean_checklist_item((string) ($item['value'] ?? ''), $title);
    if ($clean !== '') {
      return FALSE;
    }
  }
  return TRUE;
}

/**
 * Renders the "I've watched the video" toggle below the video iframe.
 *
 * Skipped when the badge has no video — the step is moot in that case.
 * The form lives just after group_video (weight=2) and before group_quiz
 * (weight=3) so it reads as a transition between the two phases.
 */
function _appointment_facilitator_attach_video_watched_form(array &$build, TermInterface $term): void {
  if (!$term->hasField('field_badge_video') || $term->get('field_badge_video')->isEmpty()) {
    return;
  }
  try {
    $form = \Drupal::formBuilder()->getForm(
      \Drupal\appointment_facilitator\Form\BadgeVideoWatchedForm::class,
      $term
    );
  }
  catch (\Throwable $e) {
    return;
  }
  if (empty($form)) {
    return;
  }
  $build['appointment_facilitator_video_watched'] = [
    '#type' => 'container',
    '#weight' => 2.5,
    '#attributes' => ['class' => ['badge-video-watched']],
    'form' => $form,
    '#cache' => [
      'contexts' => ['user'],
      'max-age' => 0,
    ],
    '#attached' => [
      'library' => ['appointment_facilitator/badge_status_banner'],
    ],
  ];
}

/**
 * Collects manual files from every tool associated with a badge.
 *
 * Returns a render array of links keyed by file URI. Empty when no
 * associated tool has a `field_manuals` value or the field doesn't exist.
 * Tool name is included in the link text so members can tell which tool
 * a given manual belongs to when multiple tools share the badge.
 */
function _appointment_facilitator_collect_tool_manuals(TermInterface $term): array {
  // Gate to authenticated viewers — some vendor manuals aren't meant for
  // public distribution and the tool pages already require login to view
  // the file field. Returning early for anonymous keeps the badge page
  // from inadvertently leaking files.
  if ((int) \Drupal::currentUser()->id() <= 0) {
    return [];
  }

  $query = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'item')
    ->condition('status', 1)
    ->sort('title', 'ASC');
  $badge_group = $query->orConditionGroup()
    ->condition('field_member_badges.target_id', (int) $term->id())
    ->condition('field_additional_badges.target_id', (int) $term->id());
  $query->condition($badge_group);
  $nids = $query->execute();
  if (!$nids) {
    return [];
  }

  $tools = Node::loadMultiple($nids);
  $items = [];
  $seen = [];
  foreach ($tools as $tool) {
    if (!$tool instanceof NodeInterface || !$tool->access('view')) {
      continue;
    }
    if (!$tool->hasField('field_manuals') || $tool->get('field_manuals')->isEmpty()) {
      continue;
    }
    foreach ($tool->get('field_manuals')->referencedEntities() as $file) {
      if (!$file || !method_exists($file, 'createFileUrl')) {
        continue;
      }
      $url = $file->createFileUrl();
      $uri = (string) $file->getFileUri();
      if (isset($seen[$uri])) {
        continue;
      }
      $seen[$uri] = TRUE;
      $name = $file->getFilename() ?: basename($uri);
      $items[] = [
        '#type' => 'inline_template',
        '#template' => '<li class="badge-tool-manuals__item"><a href="{{ url }}" class="badge-tool-manuals__link" target="_blank" rel="noopener">{{ name }}</a> <span class="badge-tool-manuals__source">— {{ tool }}</span></li>',
        '#context' => [
          'url' => $url,
          'name' => $name,
          'tool' => $tool->label(),
        ],
      ];
    }
  }

  if (!$items) {
    return [];
  }
  return [
    '#type' => 'inline_template',
    '#template' => '<ul class="badge-tool-manuals__list">{% for item in items %}{{ item }}{% endfor %}</ul>',
    '#context' => ['items' => $items],
  ];
}

/**
 * Builds the Associated Tools render array for a badge term.
 *
 * Returns an empty array when the badge has no associated tools. Caller
 * decides where to attach it — currently the page-title preprocess
 * injects it into title_prefix so it sits above the hero image.
 */
function _appointment_facilitator_build_related_tools(TermInterface $term): array {
  $query = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'item')
    ->condition('status', 1)
    ->sort('title', 'ASC');

  $badge_group = $query->orConditionGroup()
    ->condition('field_member_badges.target_id', (int) $term->id())
    ->condition('field_additional_badges.target_id', (int) $term->id());
  $query->condition($badge_group);

  $nids = $query->execute();
  if (!$nids) {
    return [];
  }

  /** @var \Drupal\node\NodeInterface[] $tools */
  $tools = Node::loadMultiple($nids);
  if (!$tools) {
    return [];
  }

  $cards = [];
  foreach ($tools as $tool) {
    if (!$tool instanceof NodeInterface || !$tool->access('view')) {
      continue;
    }

    $summary = '';
    if ($tool->hasField('body') && !$tool->get('body')->isEmpty()) {
      $body = $tool->get('body')->first();
      $summary = $body->summary ?: Unicode::truncate(trim(strip_tags((string) $body->value)), 180, TRUE, TRUE);
    }

    $image = [];
    if ($tool->hasField('field_item_image') && !$tool->get('field_item_image')->isEmpty()) {
      $image = $tool->get('field_item_image')->view([
        'label' => 'hidden',
        'type' => 'image',
        'settings' => [
          'image_style' => 'small_square',
          'image_link' => 'content',
          'image_loading' => ['attribute' => 'lazy'],
        ],
      ]);
    }

    $link = Link::fromTextAndUrl($tool->label(), $tool->toUrl())->toRenderable();
    $link['#attributes']['class'][] = 'badge-related-tools__title-link';

    $card = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['badge-related-tools__card'],
      ],
      'image' => [
        '#type' => 'container',
        '#attributes' => [
          'class' => ['badge-related-tools__image'],
        ],
        'content' => $image,
      ],
      'content' => [
        '#type' => 'container',
        '#attributes' => [
          'class' => ['badge-related-tools__content'],
        ],
        'title' => [
          '#type' => 'inline_template',
          '#template' => '<h3 class="badge-related-tools__title h5">{{ link }}</h3>',
          '#context' => [
            'link' => $link,
          ],
        ],
      ],
    ];

    if ($summary !== '') {
      $card['content']['summary'] = [
        '#type' => 'html_tag',
        '#tag' => 'p',
        '#value' => $summary,
        '#attributes' => [
          'class' => ['badge-related-tools__summary'],
        ],
      ];
    }

    $cards[] = $card;
  }

  if (!$cards) {
    return [];
  }

  $render = [
    '#type' => 'container',
    '#attached' => [
      'library' => ['appointment_facilitator/badge_related_tools'],
    ],
    '#attributes' => [
      'class' => ['badge-related-tools'],
    ],
    'title' => [
      '#type' => 'html_tag',
      '#tag' => 'h2',
      '#value' => t('Associated tools'),
      '#attributes' => [
        'class' => ['h4'],
      ],
    ],
    'cards' => [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['badge-related-tools__cards'],
      ],
      'items' => $cards,
    ],
  ];

  $cacheability = new CacheableMetadata();
  $cacheability->addCacheableDependency($term);
  $cacheability->addCacheTags(['node_list:item']);
  foreach ($tools as $tool) {
    $cacheability->addCacheableDependency($tool);
  }
  $cacheability->applyTo($render);

  return $render;
}

